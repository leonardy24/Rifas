        <mxCell id="mXCYbLK_PvB_Ia1Sqe8H-26" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;li&gt;&lt;strong style=&quot;white-space-collapse: preserve; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 12px;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(17, 17, 17));&quot;&gt;Un comprador puede tener muchos tickets&lt;/font&gt;&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(17, 17, 17)); font-size: 12px;&quot;&gt;Un ticket tiene un solo comprador (o ninguno si está libre)&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/h1&gt;" vertex="1">
